# Variables de entorno para el cuestionario MacLorian
# Copiar a .env.local para desarrollo local (NO commitear .env.local)
# Configurar las mismas variables en Vercel (Production, Preview, Development)
#
# 1. NOTION_TOKEN
#    Token de la integracion interna de Notion "MacLorian Cuestionario Web"
#    Generar en: https://www.notion.so/my-integrations
#    Permisos requeridos: Read content + Update content + Insert content
#    Formato esperado: ntn_... (o secret_... en integraciones antiguas)
NOTION_TOKEN=ntn_REEMPLAZAR_CON_TOKEN_REAL

# 2. NOTION_DATABASE_ID
#    ID de la database "Entrevistas de Validacion"
#    Hardcoded como fallback en api/submit.js, pero recomendable definirlo aqui
NOTION_DATABASE_ID=a5de9526-4375-41f4-bc7d-475dc16f0264
