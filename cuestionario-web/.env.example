# ============================================================
# VARIABLES DE ENTORNO PARA VERCEL
# ============================================================
# Estas variables se configuran en Vercel:
# Project → Settings → Environment Variables
#
# NUNCA pongas los valores reales en este archivo.
# NUNCA hagas commit de un .env real con secretos.
# ============================================================

# Token secreto de la integración de Notion.
# Lo generas en: https://www.notion.com/my-integrations
# Click "New integration" → nombre "MacLorian Cuestionario Web"
# Copy el "Internal Integration Token" (empieza con secret_ o ntn_)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la database "Entrevistas de Validación".
# Este valor ya está hardcoded como fallback en api/submit.js
# pero es buena práctica configurarlo aquí también.
NOTION_DATABASE_ID=a5de9526-4375-41f4-bc7d-475dc16f0264
